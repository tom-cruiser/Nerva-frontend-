# Copy to .env.local and fill in. Only NEXT_PUBLIC_* vars reach the browser;
# never put the Supabase SECRET key here — the browser must only use the
# publishable (anon) key.

# ─── Supabase (browser client) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ─── Backend API gateway ─────────────────────────────────────────────────────
# nginx gateway (docker-compose) on :8080. When running services directly during
# dev you can point this at a specific service, e.g. http://localhost:3001.
NEXT_PUBLIC_API_URL=http://localhost:8080
